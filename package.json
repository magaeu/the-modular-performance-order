{
    "name": "the-modular-performance-order",
    "repository": "git@github.com:the-modular-performance-order.git",
    "scripts": {
        "lint:check": "npx eslint src/*",
        "lint:fix": "npx eslint src/* --fix",
        "format: check": "npx prettier --check src/*",
        "format: fix": "npx prettier --write src/*",
        "check-types": "tsc",
        "check-types:watch": "tsc --watch",
        "land-on-page:smoke": "k6 run --config src/config/smoke.json src/tests/land.on.page.spec.ts",
        "land-on-page:load": "k6 run --config src/config/load.json src/tests/land.on.page.spec.ts",
        "login:smoke": "k6 run --config src/config/smoke.json src/tests/login.spec.ts",
        "login:load": "k6 run --config src/config/load.json src/tests/login.spec.ts"
    },
    "devDependencies": {
        "@types/dotenv": "^6.1.1",
        "@types/k6": "^2.0.0",
        "@types/node": "^25.9.3",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "dotenv": "^17.4.2",
        "eslint": "^10.5.0",
        "eslint-plugin-eslint-plugin": "^7.4.0",
        "eslint-plugin-prettier": "^5.5.6",
        "prettier": "3.8.4",
        "typescript": "^6.0.3"
    }
}
