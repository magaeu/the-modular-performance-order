{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "target": "ES2024",
        "jsx": "react-jsx",
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": true,
        "sourceMap": true,
        "types": [
            "node",
            "k6"
        ],
        "paths": {
            "@flows/*": [
                "./src/flows/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ]
        }
    },
    "include": [
        "*.ts",
        "*.mts",
        "src/**/*.ts",
    ],
    "exclude": [
        "node_modules",
        "**/node_modules/*",
        "dist",
        "test-results"
    ]
}